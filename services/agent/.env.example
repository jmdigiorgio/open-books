# Postgres (same DB as the dashboard).
DATABASE_URL=

# OpenRouter API key (LLM + web search billed through OpenRouter).
OPENROUTER_API_KEY=

# Base model slug (default: openai/gpt-4o). :online is appended automatically for pass 2.
OPENROUTER_MODEL=openai/gpt-4o

# HTTP server port.
PORT=3001

# Shared secret for /run endpoint auth. If unset, endpoint is open (local dev only).
AGENT_API_KEY=

# Delay between OpenRouter requests in ms (default 500). Prevents rate limiting.
REQUEST_DELAY_MS=500
