# Next.js does NOT load this file. Copy to .env.local for local dev (that file is loaded).
# If DASHBOARD_PASSWORD is unset in .env.local, password "dev" works for testing.

DASHBOARD_PASSWORD=

# Plaid (get from dashboard.plaid.com → Keys).
# Sandbox: test creds (user_good / pass_good). Development/Production: real bank, use that secret.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production. Use development to connect real Novo locally.
PLAID_ENV=sandbox
# Postgres (transactions, sync state, and Plaid link state).
DATABASE_URL=

# Classification agent (separate Railway service). Agent uses this to call OpenRouter for LLM.
# If the agent runs as its own service, set OPENROUTER_API_KEY in that service's env.
OPENROUTER_API_KEY=
